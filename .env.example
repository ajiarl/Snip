# Database Connection
# Supabase Postgres connection string (get from Supabase dashboard -> Settings -> Database -> Connection String)
DATABASE_URL="postgresql://user:password@host:port/database"

# Google Safe Browsing API Key
# Get from Google Cloud Console -> APIs & Services -> Credentials
# Enable "Safe Browsing API" first
# This is FREE for non-commercial use, no billing required
SAFE_BROWSING_API_KEY="your-google-safe-browsing-api-key"

# Public App URL
# Used for generating short URLs
# In production, set this to your actual domain (e.g., https://snip.to)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# IP Hash Salt
# Random string for hashing visitor IPs (privacy)
# Generate a secure random string for production
IP_HASH_SALT="change-this-to-random-string-in-production"

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"


# Google Search Console
GOOGLE_VERIFICATION_TOKEN=your_google_verification_token_here
